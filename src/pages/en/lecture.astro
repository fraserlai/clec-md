---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TweetEmbed from '../../components/TweetEmbed.astro';
import { LECTURE } from '../../config/lecture.mjs';
import { langPrefix } from '../../config/languages.mjs';
import { withBase } from '../../lib/content';

const lang = 'en' as const;
const chUrl = (c: { category: string; slug: string }) =>
  withBase(`${langPrefix(lang)}/${c.category}/${c.slug}/`);
const title = LECTURE.title[lang];
---

<BaseLayout title={`${title} · clec.md`} description={LECTURE.intro[lang]} lang={lang}>
  <article class="hub">
    <p class="kicker">★ {LECTURE.kicker[lang]}</p>
    <h1>{title}</h1>
    <p class="intro">{LECTURE.intro[lang]}</p>

    <blockquote class="creed">{LECTURE.creed[lang]}</blockquote>

    <h2>The three chapters</h2>
    <ol class="chapters">
      {
        LECTURE.chapters.map((c) => (
          <li>
            <a href={chUrl(c)}>
              <span class="num">Chapter {c.n}</span>
              <span class="ctitle">{c.title[lang]}</span>
              <span class="cblurb">{c.blurb[lang]}</span>
            </a>
          </li>
        ))
      }
    </ol>

    <h2>Full videos</h2>
    {
      LECTURE.chapters.map((c) => (
        <div class="video-block">
          <p class="video-label">
            Chapter {c.n} · {c.title[lang]}
          </p>
          <TweetEmbed url={c.tweet} lang={lang} />
        </div>
      ))
    }

    <h2>About this course</h2>
    <p>
      <em>{title}</em> is the core of CLEC — it distills 20+ years of teaching into
      three chapters. It's compiled from
      <code>價值十億元的投資講座_無圖版_v1.pdf</code> and cross-checked against the video
      transcripts (00694/00695/00696, whisper-transcribed). The three chapter pages
      also belong to their own topic categories so you can browse by subject — but if
      this is your first visit, <strong>read Chapter 1 through Chapter 3 in order</strong>.
    </p>

    <p class="disclaimer">
      Content is compiled from CLEC for education only — not personalized financial
      advice. Investing carries risk; decisions are your own.
    </p>
  </article>
</BaseLayout>

<style>
  .hub {
    max-width: 46rem;
  }
  .kicker {
    color: var(--color-brand);
    font-weight: 700;
    letter-spacing: 0.06em;
    margin: 0.5rem 0 0.2rem;
  }
  @media (prefers-color-scheme: dark) {
    .kicker {
      color: #6ee7a8;
    }
  }
  h1 {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    line-height: 1.2;
    margin: 0 0 0.6rem;
  }
  .intro {
    font-size: 1.12rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .creed {
    font-family: var(--font-serif);
    background: var(--color-brand-soft);
    border-left: 4px solid var(--color-brand);
    border-radius: 0 8px 8px 0;
    padding: 1rem 1.2rem;
    margin: 1.6rem 0;
    line-height: 1.9;
  }
  h2 {
    font-size: 1.35rem;
    margin: 2.2rem 0 1rem;
  }
  .chapters {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.7rem;
  }
  .chapters a {
    display: grid;
    gap: 0.25rem;
    padding: 1.1rem 1.2rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color 0.12s ease;
  }
  .chapters a:hover {
    border-color: var(--color-brand);
  }
  .num {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-brand);
    letter-spacing: 0.04em;
  }
  @media (prefers-color-scheme: dark) {
    .num {
      color: #6ee7a8;
    }
  }
  .ctitle {
    font-weight: 700;
    font-size: 1.15rem;
  }
  .cblurb {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.6;
  }
  code {
    font-size: 0.85em;
    background: var(--color-brand-soft);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }
  .video-block {
    margin: 0 0 1.5rem;
  }
  .video-label {
    font-weight: 600;
    color: var(--muted);
    margin: 0 0 0.3rem;
    font-size: 0.92rem;
  }
  .disclaimer {
    font-size: 0.85rem;
    color: var(--muted);
    border-top: 1px solid var(--line);
    margin-top: 2.5rem;
    padding-top: 1rem;
  }
</style>
