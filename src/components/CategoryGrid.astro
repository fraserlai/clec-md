---
import { CATEGORIES } from '../config/categories.mjs';
import { categoryUrl } from '../lib/content';

interface Props {
  lang: 'zh-TW' | 'en';
  counts?: Record<string, number>;
}
const { lang, counts = {} } = Astro.props;
---

<div class="grid">
  {
    CATEGORIES.filter((c) => c.id !== 'about').map((c) => (
      <a class="card" href={categoryUrl(lang, c.id)}>
        <span class="icon">{c.icon}</span>
        <span class="name">{c.name[lang]}</span>
        <span class="desc">{c.description[lang]}</span>
        {counts[c.id] ? <span class="count">{counts[c.id]}</span> : null}
      </a>
    ))
  }
</div>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 1rem;
  }
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.1rem 1.2rem;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    text-decoration: none;
    transition:
      transform 0.12s ease,
      border-color 0.12s ease;
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: var(--color-brand);
  }
  .icon {
    font-size: 1.5rem;
  }
  .name {
    font-weight: 700;
    font-size: 1.05rem;
  }
  .desc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
  }
  .count {
    position: absolute;
    top: 1rem;
    right: 1.1rem;
    font-size: 0.8rem;
    color: var(--color-brand);
    font-weight: 700;
  }
</style>
